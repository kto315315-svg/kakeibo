<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Kakeibo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Kakeibo">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <%# スマホ用ボトムナビ %>
<% if user_signed_in? %>
  <nav class="bottom-nav d-md-none">
    <%= link_to records_path, class: "#{request.path == records_path ? 'active' : ''}" do %>
      <span class="nav-icon">📊</span>
      <span>収支</span>
    <% end %>
    <%= link_to new_record_path, class: "#{request.path == new_record_path ? 'active' : ''}" do %>
      <span class="nav-icon">➕</span>
      <span>登録</span>
    <% end %>
    <%= link_to categories_path, class: "#{request.path == categories_path ? 'active' : ''}" do %>
      <span class="nav-icon">🏷️</span>
      <span>カテゴリ</span>
    <% end %>
    <%= link_to tags_path, class: "#{request.path == tags_path ? 'active' : ''}" do %>
      <span class="nav-icon">🔖</span>
      <span>タグ</span>
    <% end %>
    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "" do %>
      <span class="nav-icon">🚪</span>
      <span>ログアウト</span>
    <% end %>
  </nav>
<% end %>

  <body>
  <nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container">
    <%= link_to "💰 家計簿アプリ", root_path, class: "navbar-brand" %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <% if user_signed_in? %>
          <li class="nav-item"><%= link_to "収支一覧", records_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "カテゴリ管理", categories_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "タグ管理", tags_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "ログアウト", destroy_user_session_path, class: "nav-link", data: { turbo_method: :delete } %></li>
        <% else %>
          <li class="nav-item"><%= link_to "ログイン", new_user_session_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "新規登録", new_user_registration_path, class: "nav-link" %></li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>

    <main class="container mt-4">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-5">
      <p class="mb-0">家計簿アプリ © 2026</p>
    </footer>
  </body>
</html>