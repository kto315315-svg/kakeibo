<%# 月別ナビゲーション %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>収支一覧</h1>
  <%= link_to "＋ 収支を登録する", new_record_path, class: "btn btn-primary" %>
</div>

<%# 月切り替え %>
<div class="d-flex justify-content-center align-items-center mb-4 gap-3">
  <%= link_to "< 前月", records_path(year: @month == 1 ? @year - 1 : @year, month: @month == 1 ? 12 : @month - 1), class: "btn btn-outline-secondary" %>
  <h4 class="mb-0"><%= @year %>年 <%= @month %>月</h4>
  <%= link_to "次月 >", records_path(year: @month == 12 ? @year + 1 : @year, month: @month == 12 ? 1 : @month + 1), class: "btn btn-outline-secondary" %>
</div>

<%# 月別集計カード %>
<div class="row mb-4">
  <div class="col-4">
    <div class="card text-center p-3">
      <p class="text-muted mb-1" style="font-size: 0.75rem;">今月の収入</p>
      <h4 class="text-success fw-bold mb-0" style="font-size: 1.1rem;">¥<%= number_with_delimiter(@income) %></h4>
    </div>
  </div>
  <div class="col-4">
    <div class="card text-center p-3">
      <p class="text-muted mb-1" style="font-size: 0.75rem;">今月の支出</p>
      <h4 class="text-danger fw-bold mb-0" style="font-size: 1.1rem;">¥<%= number_with_delimiter(@expense) %></h4>
    </div>
  </div>
  <div class="col-4">
    <div class="card text-center p-3">
      <p class="text-muted mb-1" style="font-size: 0.75rem;">収支</p>
      <h4 class="fw-bold mb-0 <%= @balance >= 0 ? 'text-success' : 'text-danger' %>" style="font-size: 1.1rem;">
        ¥<%= number_with_delimiter(@balance) %>
      </h4>
    </div>
  </div>
</div>

<%# グラフ %>
<div class="card mb-4">
  <div class="card-body">
    <h5 class="fw-bold mb-1">📊 <%= @year %>年 <%= @month %>月 カテゴリ別支出</h5>
    <p class="mb-3" style="color: #e94560; font-size: 0.9rem; font-weight: 600;">
      合計支出：¥<%= number_with_delimiter(@expense) %>
    </p>
    <% if @chart_data.present? %>
      <div class="d-flex justify-content-center">
        <canvas id="expenseChart" style="max-width: 300px; max-height: 300px;"></canvas>
      </div>
      <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
      <script>
        const ctx = document.getElementById('expenseChart').getContext('2d');
        new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: <%= raw @chart_data.keys.to_json %>,
            datasets: [{
              data: <%= raw @chart_data.values.to_json %>,
              backgroundColor: [
                '#e94560', '#0f3460', '#f5a623', '#28a745',
                '#17a2b8', '#6f42c1', '#fd7e14', '#20c997'
              ],
              borderWidth: 2,
              borderColor: '#1a1a2e'
            }]
          },
          options: {
            responsive: true,
            plugins: {
              legend: {
                position: 'bottom',
                labels: {
                  color: '#a0a8c0',
                  padding: 12,
                  font: { size: 11 }
                }
              },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                    const percent = Math.round(context.parsed / total * 100);
                    return context.label + ': ¥' + context.parsed.toLocaleString() + ' (' + percent + '%)';
                  }
                }
              }
            }
          }
        });
      </script>
    <% else %>
      <p class="text-muted text-center">今月の支出データがありません</p>
    <% end %>
  </div>
</div>

<%# 貯金推移グラフ %>
<div class="card mb-4">
  <div class="card-body">
    <h5 class="fw-bold mb-1">💰 過去6ヶ月の収支推移</h5>
    <p class="mb-3" style="color: #f5c842; font-size: 0.9rem; font-weight: 600;">
      収支差額：
      <% total_balance = @savings_data.sum { |d| d[:balance] } %>
      <span class="<%= total_balance >= 0 ? 'text-success' : 'text-danger' %>">
        ¥<%= number_with_delimiter(total_balance) %>
      </span>
    </p>
    <canvas id="savingsChart"></canvas>
    <script>
      const savingsCtx = document.getElementById('savingsChart').getContext('2d');
      new Chart(savingsCtx, {
        type: 'bar',
        data: {
          labels: <%= raw @savings_data.map { |d| d[:month] }.to_json %>,
          datasets: [
            {
              label: '収入',
              data: <%= raw @savings_data.map { |d| d[:income] }.to_json %>,
              backgroundColor: 'rgba(40, 167, 69, 0.7)',
              borderColor: 'rgba(40, 167, 69, 1)',
              borderWidth: 2,
              borderRadius: 6,
            },
            {
              label: '支出',
              data: <%= raw @savings_data.map { |d| d[:expense] }.to_json %>,
              backgroundColor: 'rgba(233, 69, 96, 0.7)',
              borderColor: 'rgba(233, 69, 96, 1)',
              borderWidth: 2,
              borderRadius: 6,
            },
            {
              label: '残高',
              data: <%= raw @savings_data.map { |d| d[:balance] }.to_json %>,
              backgroundColor: 'rgba(245, 200, 66, 0.7)',
              borderColor: 'rgba(245, 200, 66, 1)',
              borderWidth: 2,
              borderRadius: 6,
              type: 'line',
              fill: false,
              pointBackgroundColor: '#f5c842',
              pointRadius: 5,
            }
          ]
        },
        options: {
          responsive: true,
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                color: '#a0a8c0',
                padding: 12,
                font: { size: 11 }
              }
            },
            tooltip: {
              callbacks: {
                label: function(context) {
                  return context.dataset.label + ': ¥' + context.parsed.y.toLocaleString();
                }
              }
            }
          },
          scales: {
            x: {
              ticks: { color: '#a0a8c0', font: { size: 11 } },
              grid: { color: 'rgba(255,255,255,0.05)' }
            },
            y: {
              ticks: {
                color: '#a0a8c0',
                font: { size: 11 },
                callback: function(value) {
                  return '¥' + value.toLocaleString();
                }
              },
              grid: { color: 'rgba(255,255,255,0.05)' }
            }
          }
        }
      });
    </script>
  </div>
</div>

<%# 検索・絞り込みフォーム %>
<div class="card mb-4">
  <div class="card-body">
    <%= form_with url: records_path, method: :get do |f| %>
      <div class="row g-3">
        <div class="col-md-4">
          <%= f.label :keyword, "キーワード（メモ）", class: "form-label" %>
          <%= f.text_field :keyword, value: params[:keyword], class: "form-control", placeholder: "メモを検索" %>
        </div>
        <div class="col-md-3">
          <%= f.label :category_id, "カテゴリ", class: "form-label" %>
          <%= f.collection_select :category_id, Category.all, :id, :name, { include_blank: "すべて" }, { class: "form-select" } %>
        </div>
        <div class="col-md-3">
          <%= f.label :income_or_expense, "収入/支出", class: "form-label" %>
          <%= f.select :income_or_expense, ["収入", "支出"], { include_blank: "すべて" }, { class: "form-select" } %>
        </div>
        <div class="col-md-2 d-flex align-items-end gap-2">
          <%= f.submit "検索", class: "btn btn-primary w-100" %>
          <%= link_to "リセット", records_path, class: "btn btn-secondary w-100" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# 収支一覧 %>
<div class="mb-2 d-flex justify-content-between align-items-center">
  <h5 class="fw-bold mb-0">収支一覧</h5>
  <%= link_to "＋ 登録する", new_record_path, class: "btn btn-primary btn-sm" %>
</div>

<% @records.each do |record| %>
  <div class="card mb-2">
    <div class="card-body py-2 px-3">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <span class="badge <%= record.income_or_expense == '収入' ? 'bg-success' : 'bg-danger' %> me-2">
            <%= record.income_or_expense %>
          </span>
          <span style="font-size: 0.85rem; color: #a0a8c0;"><%= record.date %></span>
        </div>
        <span class="fw-bold <%= record.income_or_expense == '収入' ? 'text-success' : 'text-danger' %>" style="font-size: 1rem;">
          ¥<%= number_with_delimiter(record.amount) %>
        </span>
      </div>
      <div class="d-flex justify-content-between align-items-center mt-1">
        <div>
          <span style="font-size: 0.8rem; color: #a0a8c0;">
            <%= record.category.name %>
            <% if record.tags.any? %>
              ・<%= record.tags.map(&:name).join(", ") %>
            <% end %>
          </span>
          <% if record.memo.present? %>
            <br><span style="font-size: 0.8rem; color: #606080;">📝 <%= record.memo %></span>
          <% end %>
        </div>
        <div class="d-flex gap-1">
          <%= link_to "編集", edit_record_path(record), class: "btn btn-sm btn-warning" %>
          <%= link_to "削除", record_path(record), class: "btn btn-sm btn-danger", data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
        </div>
      </div>
    </div>
  </div>
<% end %>